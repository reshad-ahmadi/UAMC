{
  "version": 2,
  "builds": [
    {
      "src": "Backend/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "Assoiation/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/Backend/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/Assoiation/$1"
    }
  ],
  "framework": "vite",
  "buildCommand": "cd Assoiation && pnpm install && pnpm run build",
  "outputDirectory": "Assoiation/dist"
}

